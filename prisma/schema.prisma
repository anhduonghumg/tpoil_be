// =======================================
// Datasource & Generator
// =======================================
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// =======================================
// Enums
// =======================================

enum BackgroundJobType {
  PRICE_BULLETIN_IMPORT_PDF
  SUPPLIER_INVOICE_IMPORT_PDF
}

enum BackgroundJobStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum PriceBulletinStatus {
  DRAFT
  PUBLISHED
  VOID
}

enum PaymentTermType {
  SAME_DAY
  NET_DAYS
}

enum QtyBasis {
  ACTUAL
  V15
}

enum PricingStageType {
  ESTIMATE
  BILL_NORMALIZE
  FINAL
}

enum FxStage {
  ESTIMATE
  OFFICIAL
}

enum CostLayerStatus {
  OPEN
  CLOSED
}

enum PriceSource {
  PLATTS
  MOPS
  ARGUS
  MANUAL
}

enum PurchaseCostType {
  INSURANCE
  INSPECTION
  SHIPPING
  OTHER
}

enum ContractKind {
  SALES
  PURCHASE
}

enum PartyType {
  CUSTOMER
  SUPPLIER
  INTERNAL
}

enum EmployeeStatus {
  active
  inactive
  suspended
  probation
  terminated
}

enum Gender {
  male
  female
  other
}

enum DepartmentType {
  board
  office
  group
  branch
}

enum ManagerRole {
  head
  deputy
  acting
}

enum ScopeType {
  global
  department
  site
  employee
}

enum ExportFormat {
  csv
  xlsx
  pdf
}

enum JobStatus {
  queued
  running
  done
  failed
  partial
}

enum ImportMode {
  append
  upsert
  replace
}

enum CustomerType {
  B2B
  B2C
  Distributor
  Other
}

enum CustomerRole {
  Agent
  Retail
  Wholesale
  Other
}

enum CustomerStatus {
  Active
  Inactive
  Blacklisted
}

enum TaxSource {
  Sepay
  Manual
  Other
}

enum ContractStatus {
  Draft
  Pending
  Active
  Terminated
  Cancelled
}

enum PricingRunStatus {
  DRAFT
  ESTIMATED
  NORMALIZED
  FINAL_READY
  POSTED
}

enum RiskLevel {
  Low
  Medium
  High
}

enum AttachmentCategory {
  ScanSigned
  Draft
  Appendix
  Other
}

enum RiskSource {
  Manual
  AutoRule
  Overdue
}

enum CronJobType {
  CONTRACT_EXPIRY_DAILY
}

enum CronJobStatus {
  SUCCESS
  FAILED
}

enum QtyUom {
  LITER
  KG
  UNIT
}

enum PurchaseOrderType {
  SINGLE
  LOT
}

enum PurchaseOrderStatus {
  DRAFT
  APPROVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentMode {
  PREPAID
  POSTPAID
}

enum GoodsReceiptStatus {
  DRAFT
  CONFIRMED
  VOID
}

enum SupplierInvoiceStatus {
  DRAFT
  POSTED
  VOID
}

enum ReconcileSessionStatus {
  DRAFT
  QUEUED
  PROCESSING
  READY
  CLOSED
  FAILED
}

enum InventoryAdjustmentStatus {
  DRAFT
  POSTED
  VOID
}

enum BankTxnDirection {
  IN
  OUT
}

enum BankImportStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}

enum BankTxnMatchStatus {
  UNMATCHED
  AUTO_MATCHED
  MANUAL_MATCHED
  PARTIAL_MATCHED
}

enum SettlementType {
  ADVANCE
  PAYABLE
}

enum SettlementStatus {
  OPEN
  PARTIAL
  SETTLED
  VOID
}

enum InventoryLedgerSourceType {
  GOODS_RECEIPT
  SUPPLIER_INVOICE
  INVENTORY_ADJUSTMENT
  RECONCILE_SESSION
  MANUAL
}

// =======================================
// Cron Jobs
// =======================================
model CronJob {
  id      String      @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  type    CronJobType @unique
  name    String
  enabled Boolean     @default(true)
  config  Json?

  runs CronJobRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CronJobRun {
  id String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid

  jobId String  @db.Uuid
  job   CronJob @relation(fields: [jobId], references: [id])

  runDate DateTime

  startedAt  DateTime
  finishedAt DateTime?

  status CronJobStatus

  metrics Json?
  error   String?

  createdAt DateTime @default(now())

  @@index([jobId, runDate])
}

model BackgroundJob {
  id      String            @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  type    BackgroundJobType @unique
  name    String
  enabled Boolean           @default(true)
  config  Json?

  runs BackgroundJobRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BackgroundJobRun {
  id String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid

  jobId String        @db.Uuid
  job   BackgroundJob @relation(fields: [jobId], references: [id])

  status BackgroundJobStatus @default(PENDING)

  payload Json?

  queuedAt   DateTime  @default(now())
  startedAt  DateTime?
  finishedAt DateTime?

  metrics Json?
  error   String?

  createdAt DateTime @default(now())

  @@index([jobId, queuedAt])
  @@index([status, queuedAt])
}

model JobArtifact {
  id       String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  runId    String  @db.Uuid
  kind     String
  storage  String  @default("DB")
  content  Json?
  fileUrl  String?
  checksum String?

  createdAt DateTime @default(now())

  @@index([runId, kind])
  @@index([kind, createdAt])
}

// =======================================
// Auth (User)
// =======================================
model User {
  id          String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  username    String    @unique
  email       String    @unique
  password    String
  name        String?
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee     Employee?
  roleBindings UserRoleBinding[]
}

// =======================================
// Employee – Hồ sơ nhân sự
// =======================================
model Employee {
  id   String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  code String @unique

  userId String? @unique @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  fullName      String?
  phone         String?
  workEmail     String?
  personalEmail String?        @unique
  status        EmployeeStatus @default(active)
  gender        Gender?
  nationality   String?
  maritalStatus String?

  title String?
  grade String?
  floor Int?
  desk  String?

  siteId String? @db.Uuid
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  managerId    String?    @db.Uuid
  manager      Employee?  @relation("EmpManagerLine", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates Employee[] @relation("EmpManagerLine")

  dob      DateTime?
  joinedAt DateTime?
  leftAt   DateTime?

  avatarUrl    String?
  accessCardId String? @unique

  addressPermanent String?
  addressCurrent   String?

  banking   Json?
  citizen   Json?
  emergency Json?
  tax       Json?

  memberships  EmployeeDepartment[]
  managerRoles DepartmentManager[]

  customersSalesOwner      Customer[] @relation("customer_sales_owner_emp")
  customersAccountingOwner Customer[] @relation("customer_accounting_owner_emp")
  customersLegalOwner      Customer[] @relation("customer_legal_owner_emp")
  customersDocumentOwner   Customer[] @relation("customer_document_owner_emp")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@index([deletedAt])
  @@index([code])
}

// =======================================
// Danh mục Site / Area
// =======================================
model Area {
  id   String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  code String @unique
  name String

  sites Site[]
}

model Site {
  id     String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  code   String  @unique
  name   String
  areaId String? @db.Uuid
  area   Area?   @relation(fields: [areaId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  departments Department[]
  Employee    Employee[]
}

// =======================================
// Department – Phòng ban nhiều cấp
// =======================================
model Department {
  id   String         @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  code String         @unique
  name String
  type DepartmentType

  parentId String?      @db.Uuid
  parent   Department?  @relation("DeptHierarchy", fields: [parentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  children Department[] @relation("DeptHierarchy")

  siteId String? @db.Uuid
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  costCenter String?

  members  EmployeeDepartment[]
  managers DepartmentManager[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  @@index([parentId])
  @@index([siteId])
  @@index([deletedAt])
}

// =======================================
// Liên kết nhân viên - phòng ban
// =======================================
model EmployeeDepartment {
  id           String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  employeeId   String @db.Uuid
  departmentId String @db.Uuid

  isPrimary Boolean   @default(false)
  startDate DateTime  @default(now())
  endDate   DateTime?

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId, isPrimary])
  @@index([departmentId, startDate, endDate])
  @@index([employeeId, startDate, endDate])
}

// =======================================
// Quản lý trưởng/phó phòng
// =======================================
model DepartmentManager {
  id           String      @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  departmentId String      @db.Uuid
  employeeId   String      @db.Uuid
  role         ManagerRole
  startDate    DateTime    @default(now())
  endDate      DateTime?

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departmentId, startDate, endDate])
  @@index([employeeId, startDate, endDate])
  @@index([departmentId, role, startDate, endDate])
}

// =======================================
// RBAC + Scope
// =======================================
model Module {
  id          String       @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  code        String       @unique
  name        String
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id        String           @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  code      String           @unique
  name      String
  moduleId  String           @db.Uuid
  module    Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  roles     RolePermission[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([moduleId])
}

model Role {
  id        String            @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  code      String            @unique
  name      String
  desc      String?
  perms     RolePermission[]
  bindings  UserRoleBinding[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model UserRoleBinding {
  id        String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId    String    @db.Uuid
  roleId    String    @db.Uuid
  scopeType ScopeType
  scopeId   String?
  startAt   DateTime  @default(now())
  endAt     DateTime?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([roleId])
  @@index([scopeType, scopeId])
  @@index([startAt, endAt])
}

// =======================================
// Customer / Contract
// =======================================
model CustomerGroup {
  id   String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  code String @unique

  name String?
  note String?

  customers Customer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([name])
}

model Customer {
  id          String     @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  code        String     @unique
  name        String
  taxCode     String?
  taxVerified Boolean    @default(false)
  taxSource   TaxSource?
  taxSyncedAt DateTime?

  roles     CustomerRole[]
  type      CustomerType
  partyType PartyType      @default(CUSTOMER)

  groupId String?        @db.Uuid
  group   CustomerGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  billingAddress  String?
  shippingAddress String?
  contactEmail    String?
  contactPhone    String?

  creditLimit     Decimal?
  tempLimit       Decimal?
  tempFrom        DateTime?
  tempTo          DateTime?
  paymentTermDays Int?
  status          CustomerStatus @default(Active)
  note            String?

  isCustomer Boolean @default(true)
  isSupplier Boolean @default(false)
  isInternal Boolean @default(false)

  salesOwnerEmpId      String? @db.Uuid
  accountingOwnerEmpId String? @db.Uuid
  legalOwnerEmpId      String? @db.Uuid
  documentOwnerEmpId   String? @db.Uuid

  salesOwnerEmp      Employee? @relation("customer_sales_owner_emp", fields: [salesOwnerEmpId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  accountingOwnerEmp Employee? @relation("customer_accounting_owner_emp", fields: [accountingOwnerEmpId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  legalOwnerEmp      Employee? @relation("customer_legal_owner_emp", fields: [legalOwnerEmpId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  documentOwnerEmp   Employee? @relation("customer_document_owner_emp", fields: [documentOwnerEmpId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  contacts        ContactPerson[]
  contracts       Contract[]
  riskFlags       RiskFlag[]
  creditHistories CreditLimitHistory[]
  addresses       CustomerAddress[]

  vehicles          Vehicle[]
  drivers           Driver[]
  supplierLocations SupplierLocation[]
  purchaseOrders    PurchaseOrder[]
  goodsReceipts     GoodsReceipt[]
  supplierInvoices  SupplierInvoice[]
  settlements       SupplierSettlement[]
  reconcileSessions ReconcileSession[]
  adjustments       InventoryAdjustment[]
  pricingTemplates  SupplierPricingTemplate[]
  pricingRuns       PurchasePricingRun[]
  costLayers        InventoryCostLayer[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([name])
  @@index([taxCode])
  @@index([groupId])
  @@index([partyType])
  @@index([salesOwnerEmpId])
  @@index([accountingOwnerEmpId])
  @@index([legalOwnerEmpId])
  @@index([documentOwnerEmpId])
  @@index([isCustomer])
  @@index([isSupplier])
  @@index([isInternal])
}

model CustomerAddress {
  id         String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  customerId String   @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  addressLine String
  validFrom   DateTime  @db.Date
  validTo     DateTime? @db.Date
  note        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId, validFrom])
  @@index([customerId, validTo])
  @@index([customerId])
}

model ContactPerson {
  id         String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  customerId String   @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  fullName  String
  position  String?
  phone     String?
  email     String?
  isPrimary Boolean @default(false)
}

model Contract {
  id   String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  code String @unique
  name String

  customerId String?   @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  contractTypeId String       @db.Uuid
  contractType   ContractType @relation(fields: [contractTypeId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  startDate DateTime
  endDate   DateTime

  status              ContractStatus @default(Draft)
  paymentTermDays     Int?
  creditLimitOverride Decimal?
  sla                 Json?
  deliveryScope       Json?
  riskLevel           RiskLevel      @default(Low)
  approvalRequestId   String?

  kind ContractKind @default(SALES)

  renewalOfId String?    @db.Uuid
  renewalOf   Contract?  @relation("ContractRenewal", fields: [renewalOfId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  renewals    Contract[] @relation("ContractRenewal")

  items       ContractItem[]
  appendices  ContractAppendix[]
  attachments ContractAttachment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([customerId, kind])
  @@index([status])
  @@index([startDate, endDate])
  @@index([renewalOfId])
}

model ContractType {
  id          String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  code        String  @unique
  name        String
  description String?
  isActive    Boolean @default(true)
  sortOrder   Int?

  contracts Contract[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model ContractAttachment {
  id          String             @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  contractId  String             @db.Uuid
  contract    Contract           @relation(fields: [contractId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  fileName    String
  fileUrl     String?
  externalUrl String?
  category    AttachmentCategory
}

model ContractItem {
  id         String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  contractId String   @db.Uuid
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  productId String   @db.Uuid
  uom       String
  price     Decimal
  minQty    Decimal?
  maxQty    Decimal?
  discount  Decimal?
  taxRate   Decimal?
  note      String?
}

model ContractAppendix {
  id         String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  contractId String   @db.Uuid
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  code          String
  effectiveDate DateTime
  changeSummary String?
  docUrl        String?
}

model CreditLimitHistory {
  id         String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  customerId String   @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  oldLimit  Decimal?
  newLimit  Decimal?
  tempLimit Decimal?
  tempFrom  DateTime?
  tempTo    DateTime?
  reason    String?
  changedBy String
  changedAt DateTime  @default(now())
}

model RiskFlag {
  id         String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  customerId String   @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  level     RiskLevel
  source    RiskSource
  message   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
}

// =======================================
// Mua hàng - Kho - Thanh toán (NCC = Customer)
// =======================================

model Vehicle {
  id                 String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  supplierCustomerId String   @db.Uuid
  supplier           Customer @relation(fields: [supplierCustomerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  licensePlate String
  type         String?
  capacity     Decimal? @db.Decimal(18, 3)
  note         String?
  isActive     Boolean  @default(true)

  receipts GoodsReceipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([supplierCustomerId, licensePlate])
  @@index([licensePlate])
}

model Driver {
  id                 String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  supplierCustomerId String   @db.Uuid
  supplier           Customer @relation(fields: [supplierCustomerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  fullName String
  phone    String?
  idCard   String?
  note     String?
  isActive Boolean @default(true)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  goodsReceipts GoodsReceipt[]

  @@index([fullName])
  @@index([phone])
}

model Product {
  id       String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  code     String?
  name     String
  nameMisa String?
  uom      QtyUom  @default(LITER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventoryBalances  InventoryBalance[]
  receipts           GoodsReceipt[]
  invoiceLines       SupplierInvoiceLine[]
  reconcileLines     ReconcileLine[]
  reconcileVariances ReconcileVariance[]
  adjustmentLines    InventoryAdjustmentLine[]
  snapshotLines      InventorySnapshotLine[]
  ledger             InventoryLedger[]
  purchaseOrderLines PurchaseOrderLine[]
  priceQuotes        CommodityPriceQuote[]
  pricingTemplates   SupplierPricingTemplate[]
  pricingRuns        PurchasePricingRun[]
  costLayers         InventoryCostLayer[]
  priceBulletinItems PriceBulletinItem[]

  @@index([name])
}

// ======================================================
// 1) SUPPLIER LOCATION (kho thuê NCC)
// ======================================================
model SupplierLocation {
  id                 String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  supplierCustomerId String   @db.Uuid
  supplier           Customer @relation(fields: [supplierCustomerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  code        String
  name        String
  nameInvoice String?
  address     String?
  isActive    Boolean @default(true)

  tankCode String?
  tankName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventoryBalances    InventoryBalance[]
  ledger               InventoryLedger[]
  receipts             GoodsReceipt[]
  invoiceLines         SupplierInvoiceLine[]
  reconcileSessions    ReconcileSession[]
  adjustmentLines      InventoryAdjustmentLine[]
  snapshotLines        InventorySnapshotLine[]
  costLayers           InventoryCostLayer[]
  inventoryAdjustments InventoryAdjustment[]
  purchaseOrders       PurchaseOrder[]
  purchaseOrderLines   PurchaseOrderLine[]

  @@unique([supplierCustomerId, code])
  @@index([supplierCustomerId])
  @@index([isActive])
}

// ======================================================
// 2) INVENTORY BALANCE (3 số tồn)
// ======================================================
model InventoryBalance {
  id                 String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  supplierLocationId String @db.Uuid
  productId          String @db.Uuid

  physicalQty   Decimal @default(0) @db.Decimal(18, 3)
  pendingDocQty Decimal @default(0) @db.Decimal(18, 3)
  postedQty     Decimal @default(0) @db.Decimal(18, 3)

  supplierLocation SupplierLocation @relation(fields: [supplierLocationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product          Product          @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([supplierLocationId, productId])
  @@index([supplierLocationId])
  @@index([productId])
}

// ======================================================
// 2b) INVENTORY LEDGER (thẻ kho) - append-only
// ======================================================
model InventoryLedger {
  id                 String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  supplierLocationId String @db.Uuid
  productId          String @db.Uuid

  deltaPhysicalQty   Decimal @default(0) @db.Decimal(18, 3)
  deltaPendingDocQty Decimal @default(0) @db.Decimal(18, 3)
  deltaPostedQty     Decimal @default(0) @db.Decimal(18, 3)

  afterPhysicalQty   Decimal @db.Decimal(18, 3)
  afterPendingDocQty Decimal @db.Decimal(18, 3)
  afterPostedQty     Decimal @db.Decimal(18, 3)

  sourceType InventoryLedgerSourceType
  sourceId   String                    @db.Uuid
  note       String?

  occurredAt DateTime
  createdAt  DateTime @default(now())

  supplierLocation SupplierLocation @relation(fields: [supplierLocationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product          Product          @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([supplierLocationId, productId, occurredAt])
  @@index([sourceType, sourceId])
}

// ======================================================
// 3) PURCHASE ORDER (SINGLE/LOT)
// ======================================================
model PurchaseOrder {
  id      String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  orderNo String

  supplierCustomerId String   @db.Uuid
  supplier           Customer @relation(fields: [supplierCustomerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  supplierLocationId String?           @db.Uuid
  supplierLocation   SupplierLocation? @relation(fields: [supplierLocationId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  priceRegionId String?      @db.Uuid
  priceRegion   PriceRegion? @relation(fields: [priceRegionId], references: [id], onDelete: SetNull)

  orderType   PurchaseOrderType
  status      PurchaseOrderStatus @default(DRAFT)
  paymentMode PaymentMode

  paymentTermType     PaymentTermType @default(SAME_DAY)
  paymentTermDays     Int?
  allowPartialPayment Boolean         @default(true)

  orderDate    DateTime
  expectedDate DateTime?

  note String?

  totalQty    Decimal? @db.Decimal(18, 3)
  totalAmount Decimal? @db.Decimal(18, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines    PurchaseOrderLine[]
  receipts GoodsReceipt[]

  supplierInvoices SupplierInvoice[] @relation("supplierInvoices")

  @@unique([orderNo])
  @@index([supplierCustomerId, orderDate])
  @@index([status])
  @@index([priceRegionId])
}

model PurchaseOrderLine {
  id              String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  purchaseOrderId String @db.Uuid
  productId       String @db.Uuid

  supplierLocationId String?           @db.Uuid
  supplierLocation   SupplierLocation? @relation(fields: [supplierLocationId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  orderedQty Decimal  @db.Decimal(18, 3)
  unitPrice  Decimal? @db.Decimal(18, 2)
  taxRate    Decimal? @db.Decimal(5, 2)

  discountAmount Decimal @default(0) @db.Decimal(18, 2)

  withdrawnQty Decimal @default(0) @db.Decimal(18, 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  goodsReceipts GoodsReceipt[]

  @@index([purchaseOrderId])
  @@index([productId])
  @@index([supplierLocationId, productId])
}

// ======================================================
// 4) GOODS RECEIPT (nhận hàng / rút lô) + V15
// Mode A: CONFIRMED -> tăng PendingDocQty
// ======================================================
model GoodsReceipt {
  id        String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  receiptNo String

  supplierCustomerId String   @db.Uuid
  supplier           Customer @relation(fields: [supplierCustomerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  supplierLocationId String           @db.Uuid
  supplierLocation   SupplierLocation @relation(fields: [supplierLocationId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  receiptDate DateTime
  qty         Decimal  @db.Decimal(18, 3)

  tempC          Decimal? @db.Decimal(6, 2)
  density        Decimal? @db.Decimal(10, 6)
  standardQtyV15 Decimal? @db.Decimal(18, 3)

  vehicleId String?  @db.Uuid
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  driverId String? @db.Uuid
  driver   Driver? @relation(fields: [driverId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  shippingFee Decimal? @default(0) @db.Decimal(18, 2)

  status GoodsReceiptStatus @default(DRAFT)

  purchaseOrderId     String?            @db.Uuid
  purchaseOrderLineId String?            @db.Uuid
  purchaseOrder       PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  purchaseOrderLine   PurchaseOrderLine? @relation(fields: [purchaseOrderLineId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  invoiceLines SupplierInvoiceLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([supplierCustomerId, receiptNo])
  @@index([supplierCustomerId, receiptDate])
  @@index([supplierLocationId, productId])
  @@index([status])
}

// ======================================================
// 5) SUPPLIER INVOICE
// ======================================================
model SupplierInvoice {
  id                 String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  supplierCustomerId String   @db.Uuid
  supplier           Customer @relation(fields: [supplierCustomerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  invoiceNo       String
  invoiceSymbol   String?
  invoiceTemplate String?
  invoiceDate     DateTime @db.Date

  status   SupplierInvoiceStatus @default(DRAFT)
  postedAt DateTime?

  totalAmount Decimal? @db.Decimal(18, 2)
  note        String?

  payableSettlementId String?             @db.Uuid
  payableSettlement   SupplierSettlement? @relation(fields: [payableSettlementId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  sourceFileId       String?
  sourceFileUrl      String?
  sourceFileName     String?
  sourceFileChecksum String?

  lines SupplierInvoiceLine[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  purchaseOrder   PurchaseOrder? @relation("supplierInvoices", fields: [purchaseOrderId], references: [id])
  purchaseOrderId String?        @db.Uuid

  @@unique([supplierCustomerId, invoiceSymbol, invoiceNo])
  @@index([invoiceDate])
  @@index([status])
}

model SupplierInvoiceLine {
  id        String          @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  invoiceId String          @db.Uuid
  invoice   SupplierInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  supplierLocationId String           @db.Uuid
  supplierLocation   SupplierLocation @relation(fields: [supplierLocationId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  qty Decimal @db.Decimal(18, 3)

  tempC          Decimal? @db.Decimal(6, 2)
  density        Decimal? @db.Decimal(10, 6)
  standardQtyV15 Decimal? @db.Decimal(18, 3)

  unitPrice Decimal? @db.Decimal(18, 2)
  taxRate   Decimal? @db.Decimal(5, 2)

  goodsReceiptId String?       @db.Uuid
  goodsReceipt   GoodsReceipt? @relation(fields: [goodsReceiptId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([supplierLocationId, productId])
  @@index([goodsReceiptId])
}

// ======================================================
// 6) SETTLEMENT (ADVANCE/PAYABLE) - khép vòng mua hàng
// ======================================================
model SupplierSettlement {
  id                 String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  supplierCustomerId String   @db.Uuid
  supplier           Customer @relation(fields: [supplierCustomerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  type   SettlementType
  status SettlementStatus @default(OPEN)

  amountTotal   Decimal @db.Decimal(18, 2)
  amountSettled Decimal @default(0) @db.Decimal(18, 2)

  dueDate DateTime?
  note    String?

  invoices    SupplierInvoice[]
  allocations PaymentAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierCustomerId, type, status])
  @@index([dueDate])
}

// ======================================================
// 7) ĐỐI CHIẾU KHO NCC - session + line + variance
// Không auto adjust
// ======================================================
model ReconcileSession {
  id                 String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  supplierCustomerId String   @db.Uuid
  supplier           Customer @relation(fields: [supplierCustomerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  supplierLocationId String           @db.Uuid
  supplierLocation   SupplierLocation @relation(fields: [supplierLocationId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  asOfDate DateTime               @db.Date
  status   ReconcileSessionStatus @default(DRAFT)

  sourceType   String?
  fileUrl      String?
  fileChecksum String?
  templateKey  String?

  totalLines    Int     @default(0)
  varianceLines Int     @default(0)
  errorMessage  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines     ReconcileLine[]
  variances ReconcileVariance[]

  @@unique([supplierCustomerId, supplierLocationId, asOfDate])
  @@index([supplierCustomerId, asOfDate])
  @@index([status])
}

model ReconcileLine {
  id        String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  sessionId String @db.Uuid
  productId String @db.Uuid

  supplierQty       Decimal @db.Decimal(18, 3)
  systemPhysicalQty Decimal @db.Decimal(18, 3)

  createdAt DateTime @default(now())

  session ReconcileSession @relation(fields: [sessionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product Product          @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([sessionId, productId])
  @@index([productId])
}

model ReconcileVariance {
  id        String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  sessionId String @db.Uuid
  productId String @db.Uuid

  supplierQty       Decimal @db.Decimal(18, 3)
  systemPhysicalQty Decimal @db.Decimal(18, 3)
  varianceQty       Decimal @db.Decimal(18, 3)

  explanation String?
  resolvedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session ReconcileSession @relation(fields: [sessionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product Product          @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([sessionId, productId])
  @@index([varianceQty])
}

// ======================================================
// 8) INVENTORY ADJUSTMENT
// ======================================================
model InventoryAdjustment {
  id                 String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  supplierCustomerId String   @db.Uuid
  supplier           Customer @relation(fields: [supplierCustomerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  supplierLocationId String           @db.Uuid
  supplierLocation   SupplierLocation @relation(fields: [supplierLocationId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  status InventoryAdjustmentStatus @default(DRAFT)

  adjustmentDate DateTime
  reason         String?
  note           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines InventoryAdjustmentLine[]

  @@index([supplierCustomerId, supplierLocationId])
  @@index([status])
  @@index([adjustmentDate])
}

model InventoryAdjustmentLine {
  id                 String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  adjustmentId       String @db.Uuid
  supplierLocationId String @db.Uuid
  productId          String @db.Uuid

  adjustPhysicalQty Decimal @db.Decimal(18, 3)
  note              String?

  createdAt DateTime @default(now())

  adjustment       InventoryAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  supplierLocation SupplierLocation    @relation(fields: [supplierLocationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  product          Product             @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([productId])
  @@index([supplierLocationId, productId])
}

// ======================================================
// 9) SNAPSHOT INVENTORY
// ======================================================
model InventorySnapshot {
  id           String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  asOfAt       DateTime
  source       String?
  warningCount Int      @default(0)

  createdAt DateTime @default(now())

  lines InventorySnapshotLine[]

  @@unique([asOfAt])
}

model InventorySnapshotLine {
  id                 String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  snapshotId         String @db.Uuid
  supplierLocationId String @db.Uuid
  productId          String @db.Uuid

  physicalQty   Decimal @db.Decimal(18, 3)
  pendingDocQty Decimal @db.Decimal(18, 3)
  postedQty     Decimal @db.Decimal(18, 3)

  hasVariance Boolean @default(false)

  createdAt DateTime @default(now())

  snapshot         InventorySnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  supplierLocation SupplierLocation  @relation(fields: [supplierLocationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  product          Product           @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([snapshotId, supplierLocationId, productId])
  @@index([supplierLocationId, productId])
}

// ======================================================
// 10) QUỸ / NGÂN HÀNG - SAO KÊ
// ======================================================
model BankAccount {
  id          String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  bankCode    String
  bankName    String?
  accountNo   String
  accountName String?
  currency    String  @default("VND")
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  imports      BankStatementImport[]
  transactions BankTransaction[]

  @@unique([bankCode, accountNo])
  @@index([isActive])
}

model BankImportTemplate {
  id       String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  bankCode String
  name     String
  version  Int    @default(1)

  columnMap     Json
  normalizeRule Json?
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  imports BankStatementImport[]

  @@unique([bankCode, name, version])
  @@index([bankCode, isActive])
}

model BankStatementImport {
  id            String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  bankAccountId String  @db.Uuid
  templateId    String? @db.Uuid

  status BankImportStatus @default(QUEUED)

  fileUrl      String
  fileChecksum String?
  startedAt    DateTime?
  finishedAt   DateTime?

  importedCount   Int @default(0)
  duplicatedCount Int @default(0)
  failedCount     Int @default(0)

  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bankAccount      BankAccount         @relation(fields: [bankAccountId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  template         BankImportTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  bankTransactions BankTransaction[]

  createdBy String? @db.Uuid

  @@unique([bankAccountId, fileChecksum])
  @@index([bankAccountId, status])
  @@index([createdAt])
}

model BankTransaction {
  id            String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  bankAccountId String  @db.Uuid
  importId      String? @db.Uuid

  txnDate   DateTime
  direction BankTxnDirection
  amount    Decimal          @db.Decimal(18, 2)

  description      String
  counterpartyName String?
  counterpartyAcc  String?

  externalRef String?
  fingerprint String

  matchStatus BankTxnMatchStatus @default(UNMATCHED)

  raw Json?

  postedDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bankAccount BankAccount          @relation(fields: [bankAccountId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  import      BankStatementImport? @relation(fields: [importId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  allocations PaymentAllocation[]

  isConfirmed Boolean   @default(false)
  confirmedAt DateTime?
  confirmedBy String?   @db.Uuid

  @@unique([bankAccountId, externalRef])
  @@unique([bankAccountId, fingerprint])
  @@index([bankAccountId, txnDate])
  @@index([matchStatus])
  @@index([externalRef])
  @@index([fingerprint])
}

model PaymentAllocation {
  id                String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  bankTransactionId String @db.Uuid
  settlementId      String @db.Uuid

  allocatedAmount Decimal @db.Decimal(18, 2)

  isAuto Boolean @default(false)
  score  Int?
  note   String?

  sortOrder Int? @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bankTransaction BankTransaction    @relation(fields: [bankTransactionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  settlement      SupplierSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([bankTransactionId, settlementId])
  @@index([bankTransactionId])
  @@index([settlementId])
}

// ======================================================
// TERM - Quotes / FX / PricingRun / FIFO Layer
// ======================================================
model CommodityPriceQuote {
  id        String      @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  productId String      @db.Uuid
  quoteDate DateTime    @db.Date
  source    PriceSource @default(PLATTS)

  priceUsdPerBbl Decimal @db.Decimal(18, 6)
  note           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([productId, quoteDate, source])
  @@index([productId, quoteDate])
}

model ExchangeRate {
  id       String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  rateDate DateTime @db.Date
  base     String   @default("USD")
  quote    String   @default("VND")

  stage FxStage @default(ESTIMATE)
  rate  Decimal @db.Decimal(18, 6)

  note      String?
  createdAt DateTime @default(now())

  @@unique([rateDate, base, quote, stage])
}

model SupplierPricingTemplate {
  id                 String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  supplierCustomerId String   @db.Uuid
  supplier           Customer @relation(fields: [supplierCustomerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  qtyBasisDefault  QtyBasis @default(ACTUAL)
  useBillNormalize Boolean  @default(false)
  useReconcile     Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([supplierCustomerId, productId])
}

model PurchasePricingRun {
  id                 String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  supplierCustomerId String   @db.Uuid
  supplier           Customer @relation(fields: [supplierCustomerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  billDate DateTime @db.Date

  qtyBasisSelected QtyBasis
  qtyBasisLocked   Boolean  @default(false)

  qtyActualTotal Decimal? @db.Decimal(18, 3)
  qtyV15Total    Decimal? @db.Decimal(18, 3)

  status PricingRunStatus @default(DRAFT)

  stages PurchasePricingStage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierCustomerId, billDate])
  @@index([status])
}

model PurchasePricingStage {
  id        String           @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  runId     String           @db.Uuid
  stageType PricingStageType

  mopsAvgUsdPerBbl Decimal? @db.Decimal(18, 6)
  premiumUsdPerBbl Decimal? @db.Decimal(18, 6)

  unitUsdPerBbl Decimal? @db.Decimal(18, 6)
  amountUsd     Decimal? @db.Decimal(18, 6)

  fxRateDate DateTime? @db.Date
  fxStage    FxStage   @default(ESTIMATE)
  fxRate     Decimal?  @db.Decimal(18, 6)

  insuranceAmountVnd Decimal? @db.Decimal(18, 2)
  shippingFeeVnd     Decimal? @db.Decimal(18, 2)
  otherFeeVnd        Decimal? @db.Decimal(18, 2)

  envTaxAmountVnd Decimal? @db.Decimal(18, 2)
  vatAmountVnd    Decimal? @db.Decimal(18, 2)

  amountVndBeforeTax Decimal? @db.Decimal(18, 2)
  totalAmountVnd     Decimal? @db.Decimal(18, 2)
  unitVndPerLiter    Decimal? @db.Decimal(18, 6)

  note String?

  priceDays PurchasePricingPriceDay[]

  run PurchasePricingRun @relation(fields: [runId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([runId, stageType])
}

model PurchasePricingPriceDay {
  id             String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  stageId        String   @db.Uuid
  quoteDate      DateTime @db.Date
  priceUsdPerBbl Decimal  @db.Decimal(18, 6)

  stage PurchasePricingStage @relation(fields: [stageId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([stageId, quoteDate])
}

model InventoryCostLayer {
  id String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid

  supplierCustomerId String   @db.Uuid
  supplier           Customer @relation(fields: [supplierCustomerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  supplierLocationId String           @db.Uuid
  supplierLocation   SupplierLocation @relation(fields: [supplierLocationId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  sourceType String
  sourceId   String @db.Uuid

  originalQty  Decimal @db.Decimal(18, 3)
  remainingQty Decimal @db.Decimal(18, 3)

  unitCostPerLiter Decimal @db.Decimal(18, 6)
  totalCost        Decimal @db.Decimal(18, 2)

  costDate DateTime
  status   CostLayerStatus @default(OPEN)

  createdAt DateTime @default(now())

  @@index([supplierCustomerId])
  @@index([supplierLocationId])
  @@index([productId, status, costDate])
  @@index([sourceType, sourceId])
}

model PriceRegion {
  id   String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  code String  @unique
  name String
  note String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items          PriceBulletinItem[]
  purchaseOrders PurchaseOrder[]

  @@index([isActive])
}

model PriceBulletin {
  id String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid

  status PriceBulletinStatus @default(PUBLISHED)

  publishedAt   DateTime  @db.Timestamptz
  effectiveFrom DateTime  @db.Timestamptz
  effectiveTo   DateTime? @db.Timestamptz

  source       String?
  fileUrl      String?
  fileChecksum String?
  note         String?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items PriceBulletinItem[]

  @@unique([publishedAt])
  @@unique([fileChecksum])
  @@index([status, effectiveFrom])
  @@index([publishedAt])
}

model PriceBulletinItem {
  id String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid

  bulletinId String @db.Uuid
  productId  String @db.Uuid
  regionId   String @db.Uuid

  price Decimal @db.Decimal(18, 2)
  note  String?

  bulletin PriceBulletin @relation(fields: [bulletinId], references: [id], onDelete: Cascade)
  product  Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  region   PriceRegion   @relation(fields: [regionId], references: [id], onDelete: Restrict)

  @@unique([bulletinId, productId, regionId])
  @@index([productId, regionId])
}

// =======================================
// Audit Log
// =======================================
model AuditLog {
  id String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid

  requestId  String?  @db.Uuid
  at         DateTime @default(now())
  userId     String?  @db.Uuid
  ip         String?
  ua         String?
  method     String?
  path       String?
  statusCode Int?

  moduleCode String?
  permission String?
  action     String?
  entityId   String?    @db.Uuid
  scopeType  ScopeType?
  scopeId    String?    @db.Uuid

  before Json?
  after  Json?
  diff   Json?
  error  Json?

  @@index([userId, at])
  @@index([moduleCode, action, at])
  @@index([entityId])
}

// =======================================
// Export / Import Jobs
// =======================================
model ExportJob {
  id         String       @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  moduleCode String
  format     ExportFormat
  filter     Json?
  status     JobStatus    @default(queued)
  fileUrl    String?
  error      String?

  createdBy  String
  createdAt  DateTime  @default(now())
  finishedAt DateTime?

  @@index([moduleCode, status, createdBy, createdAt])
}

model ImportJob {
  id         String     @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  moduleCode String
  mode       ImportMode
  mapping    Json?
  status     JobStatus  @default(queued)
  total      Int?
  success    Int?
  failed     Int?
  srcFileUrl String?
  reportUrl  String?
  error      String?

  createdBy  String
  createdAt  DateTime  @default(now())
  finishedAt DateTime?

  @@index([moduleCode, status, createdBy, createdAt])
}

model LoginAttempt {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  username  String?
  email     String
  ok        Boolean
  ip        String?
  ua        String?
  createdAt DateTime @default(now())
}
